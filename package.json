{
  "name": "@jsdr/xhgui-mcp",
  "version": "0.1.0",
  "description": "MCP server for querying XHGui profiling data",
  "type": "module",
  "bin": {
    "xhgui-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs/design.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jensderond/xhgui-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Jensderond/xhgui-mcp/issues"
  },
  "homepage": "https://github.com/Jensderond/xhgui-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/server.js",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "mysql2": "^3.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
